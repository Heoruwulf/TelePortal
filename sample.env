# ==============================================================================
# TelePortal: Core Service Configuration
# ==============================================================================
# Use this file as a template for your .env file.
# Values marked as [REQUIRED] must be set for production.
# Values marked as [OPTIONAL] have sane defaults provided.

# ------------------------------------------------------------------------------
# 1. Logging & Observability
# ------------------------------------------------------------------------------

# Minimum log level (debug, info, warn, error). Default: info
TELEPORTAL_LOG_LEVEL=info

# Log format (console, json). Use json for production. Default: console
TELEPORTAL_LOG_FORMAT=console

# Path to write log files. If empty, logs to stdout. Default: empty
TELEPORTAL_LOG_PATH=

# Enable runtime profiling endpoint at :6060/debug/pprof. Default: false
TELEPORTAL_FEATURES_PPROF=false

# Enable Prometheus metrics endpoint at :8080/metrics. Default: false
TELEPORTAL_FEATURES_PROMETHEUS=false


# ------------------------------------------------------------------------------
# 2. SIP Signaling (VoIP)
# ------------------------------------------------------------------------------

# IP address to bind the SIP UDP listener. Default: 0.0.0.0
TELEPORTAL_SIP_BIND_ADDRESS=0.0.0.0

# Port to bind the SIP UDP listener. Default: 5060
TELEPORTAL_SIP_BIND_PORT=5060

# Public IP to advertise in SIP/SDP (Critical for NAT). [REQUIRED for Production]
TELEPORTAL_SIP_EXTERNAL_ADDRESS=

# Public Port to advertise in SIP/SDP. If 0, uses BIND_PORT. Default: 0
TELEPORTAL_SIP_EXTERNAL_PORT=0

# Maximum number of concurrent calls this instance will accept. 
# If 0, capacity is unlimited. When limit is reached, responds with 486 Busy Here. Default: 0
TELEPORTAL_MAX_CALLS=0



# ------------------------------------------------------------------------------
# 3. RTP Media Handling
# ------------------------------------------------------------------------------

# IP address to bind the RTP UDP listeners. Default: 0.0.0.0
TELEPORTAL_RTP_BIND_ADDRESS=0.0.0.0

# Public IP to advertise in SDP for media streams. [REQUIRED for Production]
TELEPORTAL_RTP_EXTERNAL_ADDRESS=

# Minimum port for dynamic RTP allocation. Default: 10000
TELEPORTAL_RTP_PORT_MIN=10000

# Maximum port for dynamic RTP allocation. Default: 20000
TELEPORTAL_RTP_PORT_MAX=20000


# ------------------------------------------------------------------------------
# 4. Audio Processing
# ------------------------------------------------------------------------------

# Minimum packets to buffer in the jitter buffer before playback. Default: 50
TELEPORTAL_AUDIO_JB_MIN_PACKETS=50

# Directory to save stereo WAV recordings. If empty, recording is disabled.
TELEPORTAL_AUDIO_RECORDING_PATH=./recordings

# Audio codec to use for WebSocket streams. [REQUIRED]
# Valid values:
#   L16  - 16-bit (Little-Endian) Linear PCM (8000Hz, Mono).
#   PCMU - G.711 mu-law (8000Hz, Mono).
#   PCMA - G.711 A-law (8000Hz, Mono).
#   PASS - Zero-transcoding passthrough. Automatically matches the codec
#          negotiated via SIP. This is the most efficient mode.
#          Note: If L16 is negotiated, PASS mode uses Big-Endian (Network Order).
TELEPORTAL_WS_CODEC=PASS


# ------------------------------------------------------------------------------
# 5. HTTP & WebSocket API
# ------------------------------------------------------------------------------

# Address and port for the HTTP/WebSocket server. Default: 0.0.0.0:8080
TELEPORTAL_HTTP_BIND_ADDRESS=0.0.0.0:8080

# The public URL of this instance (used for Webhook notifications). [REQUIRED]
TELEPORTAL_HTTP_PUBLIC_URL=http://localhost:8080

# Allowed origins for CORS. Default: *
TELEPORTAL_HTTP_CORS_ORIGINS=*


# ------------------------------------------------------------------------------
# 6. Security & Authentication
# ------------------------------------------------------------------------------

# Secret key for JWT validation. If empty, WebSocket auth is DISABLED.
# TELEPORTAL_AUTH_JWT_SECRET=your-secure-random-secret


# ------------------------------------------------------------------------------
# 7. Redis (Distributed State & Notifications)
# ------------------------------------------------------------------------------

# Redis server address. (Use localhost:6379 for host networking). Default: localhost:6379
TELEPORTAL_REDIS_ADDRESS=localhost:6379

# Redis password. Optional.
TELEPORTAL_REDIS_PASSWORD=

# Redis database index. Default: 0
TELEPORTAL_REDIS_DB=0


# ------------------------------------------------------------------------------
# 8. Application Lifecycle
# ------------------------------------------------------------------------------

# Maximum time to wait for active calls to finish during a graceful shutdown 
# (e.g., SIGTERM). If calls persist beyond this timeout, the server will force quit.
# Default: 5m
TELEPORTAL_SHUTDOWN_TIMEOUT=5m
